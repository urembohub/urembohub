# Database
DATABASE_URL="postgresql://username:password@localhost:5432/urembo_hub?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-here"
JWT_EXPIRES_IN="7d"

# Application
PORT=3000
NODE_ENV=development

# API URL - Full base URL where your backend is hosted (without /api suffix)
# Used for constructing absolute URLs (e.g., image URLs in emails, webhooks)
# Development:
API_URL=http://localhost:3000
# Staging:
# API_URL=https://api-staging.urembohub.com
# Production:
# API_URL=https://api.urembohub.com

# Frontend URL - Where your frontend is hosted
# Used for redirects and CORS
# Development:
FRONTEND_URL=http://localhost:5173
# Staging:
# FRONTEND_URL=https://staging.urembohub.com
# Production:
# FRONTEND_URL=https://urembohub.com

# External Services
PAYSTACK_SECRET_KEY="your-paystack-secret-key"
PAYSTACK_PUBLIC_KEY="your-paystack-public-key"
RESEND_API_KEY="your-resend-api-key"

# Redis Configuration for BullMQ
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Email
FROM_EMAIL="noreply@urembohub.com"
FROM_NAME="Urembo Hub"
